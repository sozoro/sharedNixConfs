set encoding=utf-8
scriptencoding utf-8
filetype off
filetype plugin indent off

set isk+=-
set isk+=+
set isk+=*
set expandtab
set tabstop=2
set shiftwidth=2
set shiftround
set hidden
set list
set listchars=tab:»-,trail:-,extends:»,precedes:«,nbsp:%
set backspace=indent,eol,start
set cursorline
set autoindent
set smartindent
set noequalalways
set ruler
set display=lastline
set wildmode=list:longest,full
set mouse-=a
set path+=**
set foldmethod=indent
set nofoldenable
set wildignore+=tags
set wildignorecase
let maplocalleader = "\\"
let g:netrw_banner=0

try
  set fillchars=vert:\│
catch
  set fillchars=vert:\|
endtry

imap <silent> jj <ESC>
noremap <C-w>q <Nop>

syntax on

if has('win32') || has('win64')
  set t_Co=256
  set shell=C:\Windows\System32\WindowsPowerShell\v1.0\powershell.exe
endif

if v:version > 800
  set termguicolors
endif

function! MyHighlights() abort
  highlight Normal                                         ctermbg=NONE guibg=NONE
  highlight Nontext                                        ctermbg=NONE guibg=NONE
  highlight Folded                                         ctermbg=NONE guibg=NONE
  highlight FoldedColumn                                   ctermbg=NONE guibg=NONE
  highlight EndOfBuffer                                    ctermbg=NONE guibg=NONE
  highlight CursorLine       cterm=none      gui=none      ctermbg=234  guibg=#1c1c1c
  highlight StatusLine       cterm=underline gui=underline ctermbg=NONE guibg=NONE    ctermfg=24 guifg=#005f87
  highlight StatusLineNC     cterm=underline gui=underline ctermbg=NONE guibg=NONE    ctermfg=8  guifg=#5F6149
  highlight StatusLineTerm   cterm=underline gui=underline ctermbg=NONE guibg=NONE    ctermfg=24 guifg=#005f87
  highlight StatusLineTermNC cterm=underline gui=underline ctermbg=NONE guibg=NONE    ctermfg=8  guifg=#5F6149
  highlight VertSplit        cterm=none      gui=none                                 ctermfg=8  guifg=#5F6149
  highlight Folded                                                                    ctermfg=6  guifg=Teal
endfunction

call MyHighlights()

augroup MyHighlights
  autocmd!
  autocmd VimEnter,WinEnter,ColorScheme * call MyHighlights()
augroup END

autocmd Filetype tex setlocal foldmarker=@{{{,@}}}
autocmd Filetype tex setlocal foldmethod=marker
autocmd Filetype tex syntax match texStatement "\\[a-zA-Z_:@]\+"
autocmd Filetype tex setlocal iskeyword+=:
autocmd Filetype tex let g:tex_no_math=0
