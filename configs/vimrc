if has('patch-7.4.006')
  set directory=~/.vim/tmp/swp
  set backupdir=~/.vim/tmp/backup
  set undodir=~/.vim/tmp/undo
  call mkdir(&l:directory, 'p', 0700)
  call mkdir(&l:backupdir, 'p', 0700)
  call mkdir(&l:undodir, 'p', 0700)
endif

function! ToggleIndentGuides()
  if exists('b:indent_guides')
    call matchdelete(b:indent_guides)
    unlet b:indent_guides
  else
    let l:textwidth = max([&l:textwidth, winwidth(0), strwidth(getline('.'))])
    let l:pos = range(1, l:textwidth, &l:shiftwidth)
    call map(l:pos, '"\\%" . v:val . "v"')
    let pat = '\%(\_^\s*\)\@<=\%(' . join(pos, '\|') . '\)\s'
    let b:indent_guides = matchadd('CursorLine', pat)
  endif
endfunction

function! SetTerminalName()
  let l:current_bufnr = bufnr('%')
  for l:term_bufnr in term_list()
    let l:title = term_gettitle(l:term_bufnr)
    if ! empty(l:title)
      let l:status = getbufinfo(l:term_bufnr)[0]['hidden'] ? 'H' : 'A'
      execute 'buffer' l:term_bufnr
      execute 'file' ('T' . l:status . l:term_bufnr . l:title)
    endif
  endfor
  execute 'buffer' l:current_bufnr
endfunction

function! QuitHiddenTerminals()
  let l:current_bufnr = bufnr('%')
  for l:term_bufnr in term_list()
    if getbufinfo(l:term_bufnr)[0]['hidden']
      execute 'bwipeout!' l:term_bufnr
    endif
  endfor
  execute 'buffer' l:current_bufnr
endfunction

" terminal-api
function! Tapi_TCD(bufnum, arglist)
  if a:arglist[1] == '-f'
    windo execute 'cd' fnameescape(a:arglist[0])
  else
    execute 'tcd' fnameescape(a:arglist[0])
  endif
endfunction

command! Terminal terminal ++close ++curwin
command! -bar Scratch new | setlocal buftype=nofile | setlocal bufhidden=wipe
command! -bar VScratch vertical new | setlocal buftype=nofile | setlocal bufhidden=wipe

let s:ex_rc = findfile('.vimrc', '.;')
if len(s:ex_rc) > 0
  execute 'source ' . s:ex_rc
endif

filetype plugin indent on
